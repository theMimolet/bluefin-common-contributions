{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>projectbluefin/renovate-config"
  ],
  "packageRules": [
    {
      "description": "Automerge chore dep updates (digest, pin, patch, minor) when CI passes",
      "matchUpdateTypes": [
        "digest",
        "pin",
        "patch",
        "minor"
      ],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Group and automerge projectbluefin/actions composite SHA updates into one PR",
      "matchManagers": ["github-actions"],
      "groupName": "projectbluefin/actions",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "labels": ["chore/deps", "automerge"],
      "matchDepNames": [
        "/projectbluefin/actions/"
      ]
    }
  ]
}
